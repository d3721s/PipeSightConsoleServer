PIPESIGHT_HOST=0.0.0.0
PIPESIGHT_PORT=8000
PIPESIGHT_FFMPEG_EXE=ffmpeg
PIPESIGHT_MEDIAMTX_EXE=/usr/local/bin/mediamtx
PIPESIGHT_MEDIAMTX_CONFIG=./third_party/mediamtx/mediamtx.yml
PIPESIGHT_MEDIAMTX_RTSP_PORT=8554
PIPESIGHT_MEDIAMTX_WEBRTC_PORT=8889
PIPESIGHT_MEDIAMTX_RTSP_TRANSPORT=udp
PIPESIGHT_PREVIEW_RTSP_SUBTYPE=0
# Optional. Extra IP/hostnames MediaMTX advertises as WebRTC ICE candidates.
# Leave empty to auto-detect (works on a single LAN). Set to the server LAN IP
# for Docker / multi-NIC / NAT setups. Comma-separated.
# PIPESIGHT_MEDIAMTX_WEBRTC_ADDITIONAL_HOSTS=192.168.213.129
PIPESIGHT_RECORDING_SEGMENT_MINUTES=30
PIPESIGHT_IMU_SERIAL_PORT=/dev/ttyUSB-IMU
PIPESIGHT_IMU_BAUDRATE=115200
PIPESIGHT_POINTCLOUD_BRIDGE_WS_URL=ws://127.0.0.1:9090
PIPESIGHT_DEPTH_BRIDGE_WS_URL=ws://127.0.0.1:9091
